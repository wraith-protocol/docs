{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Wraith Protocol",
  "logo": {
    "dark": "/assets/images/logo-white.png",
    "light": "/assets/images/logo-black.png"
  },
  "favicon": "/assets/images/logo-black.png",
  "colors": {
    "primary": "#c6c6c7",
    "light": "#e6e1e5",
    "dark": "#767575",
